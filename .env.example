# ─────────────────────────────────────────────────────────────────────────────
# MessageOS — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# On Render, set these as Environment Variables in the dashboard.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ntfy.sh push notifications ───────────────────────────────────────────────
# Your personal ntfy.sh topic URL
NTFY_URL=https://ntfy.sh/MessageOS-Rishabh
# Bearer token for authenticated publishing (prevents strangers from spamming your topic)
NTFY_TOKEN=tk_b87dqlt8prlg9gkpsrakf58dwmkhf

# ── Contact tiers ─────────────────────────────────────────────────────────────
# Comma-separated phone numbers of VIP contacts (include country code: +1xxxxxxxxxx)
# These get instant urgent alerts and 18/20-min SLA clocks
VIP_PHONES=+1xxxxxxxxxx,+1xxxxxxxxxx
# Comma-separated email addresses of VIP contacts
VIP_EMAILS=example@gmail.com,another@gmail.com
# Comma-separated phone numbers of Important contacts (2-hour SLA clock)
IMPORTANT_PHONES=
# Comma-separated emails of Important contacts
IMPORTANT_EMAILS=

# ── Render deployment ────────────────────────────────────────────────────────
# Your Render service URL — used by the keep-alive pinger (runs every 14 min)
RENDER_URL=https://messageos.onrender.com

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (Settings → Database → Connection string → URI)
# Use the "Session mode" URI (port 5432), not the transaction pooler.
DATABASE_URL=postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres

# ── Google / Gmail / Calendar (Phase 2) ──────────────────────────────────────
# Absolute path to the downloaded Google OAuth2 client secrets JSON
GOOGLE_CREDENTIALS_PATH=/Users/rishabh/Library/Mobile Documents/com~apple~CloudDocs/Claude Automations/MessageOS/client_secret_638262079378-t7svi26m35c7i5icfn8kamjb8fekm8o0.apps.googleusercontent.com.json
# OAuth2 token cache — created automatically on first run
GOOGLE_TOKEN_PATH=./token.json

# ── Obsidian vault (Phase 3) ──────────────────────────────────────────────────
# Absolute path to the Obsidian vault root that syncs to iPhone via iCloud
OBSIDIAN_VAULT_PATH=/Users/rishabh/Library/Mobile Documents/iCloud~md~obsidian/Documents/MessageOS
